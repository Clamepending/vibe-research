#!/usr/bin/env node

import path from "node:path";
import process from "node:process";
import { readFile } from "node:fs/promises";

function printHelp() {
  process.stdout.write(`vr-agent-canvas

Publish the current Vibe Research session's visible agent canvas image.

Usage:
  vr-agent-canvas --image PATH --title TITLE [--caption TEXT]
  vr-agent-canvas --url URL --title TITLE [--caption TEXT]
  vr-agent-canvas --clear

Options:
  --session-id ID       Override VIBE_RESEARCH_SESSION_ID.
  --agent-id ID         Associate the canvas with a subagent.
  --image PATH          Workspace-relative or absolute image path.
  --url URL             Remote image URL.
  --title TEXT          Short title shown in the agent profile.
  --caption TEXT        Short caption shown below the image.
  --alt TEXT            Image alt text.
  --href URL            Open-link URL; defaults to the image.
  --json                Print the API response as JSON.

Examples:
  vr-agent-canvas --image results/chart.png --title "Latest graph" --caption "Best qualitative result so far."
  vr-agent-canvas --clear
`);
}

function requireValue(args, index, flag) {
  const value = args[index + 1];
  if (!value || value.startsWith("--")) {
    throw new Error(`${flag} requires a value.`);
  }
  return value;
}

function parseArgs(args) {
  const options = {
    agentId: "",
    alt: "",
    caption: "",
    clear: false,
    href: "",
    imagePath: "",
    imageUrl: "",
    json: false,
    sessionId: "",
    title: "",
  };

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];
    if (arg === "--help" || arg === "-h") {
      options.help = true;
    } else if (arg === "--json") {
      options.json = true;
    } else if (arg === "--clear") {
      options.clear = true;
    } else if (arg === "--session-id") {
      options.sessionId = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--agent-id") {
      options.agentId = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--image" || arg === "--path") {
      options.imagePath = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--url" || arg === "--image-url") {
      options.imageUrl = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--title") {
      options.title = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--caption") {
      options.caption = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--alt") {
      options.alt = requireValue(args, index, arg);
      index += 1;
    } else if (arg === "--href") {
      options.href = requireValue(args, index, arg);
      index += 1;
    } else if (!arg.startsWith("--") && !options.imagePath && !options.imageUrl) {
      options.imagePath = arg;
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }

  return options;
}

async function readServerInfo(rootDir) {
  const filePath = path.join(rootDir, "server.json");
  const raw = await readFile(filePath, "utf8");
  return JSON.parse(raw);
}

async function resolveAgentTownApi() {
  const directApi = String(
    process.env.VIBE_RESEARCH_AGENT_TOWN_API ||
      process.env.REMOTE_VIBES_AGENT_TOWN_API ||
      "",
  ).trim();
  if (directApi) {
    return directApi.replace(/\/+$/, "");
  }

  const rootDir = String(process.env.VIBE_RESEARCH_ROOT || process.env.REMOTE_VIBES_ROOT || "").trim();
  if (!rootDir) {
    throw new Error("VIBE_RESEARCH_AGENT_TOWN_API or VIBE_RESEARCH_ROOT is required.");
  }

  const serverInfo = await readServerInfo(rootDir);
  const baseUrl = String(serverInfo?.helperBaseUrl || "").trim().replace(/\/+$/, "");
  if (!baseUrl) {
    throw new Error("Vibe Research server metadata does not include helperBaseUrl.");
  }

  return `${baseUrl}/api/agent-town`;
}

async function fetchJsonOrThrow(url, options) {
  const response = await fetch(url, options);
  const payload = await response.json().catch(() => ({}));
  if (!response.ok) {
    throw new Error(payload?.error || `${response.status} ${response.statusText}`.trim());
  }
  return payload;
}

async function main() {
  const options = parseArgs(process.argv.slice(2));
  if (options.help) {
    printHelp();
    return;
  }

  const sessionId = String(
    options.sessionId ||
      process.env.VIBE_RESEARCH_SESSION_ID ||
      process.env.REMOTE_VIBES_SESSION_ID ||
      "",
  ).trim();
  if (!sessionId) {
    throw new Error("VIBE_RESEARCH_SESSION_ID is not set; pass --session-id.");
  }

  const agentTownApi = await resolveAgentTownApi();
  const canvasId = options.agentId ? `${sessionId}-${options.agentId}` : sessionId;

  if (options.clear) {
    const payload = await fetchJsonOrThrow(`${agentTownApi}/canvases/${encodeURIComponent(canvasId)}`, {
      method: "DELETE",
    });
    if (options.json) {
      process.stdout.write(`${JSON.stringify(payload, null, 2)}\n`);
    } else {
      process.stdout.write(`cleared canvas ${payload.canvas?.id || canvasId}\n`);
    }
    return;
  }

  if (!options.imagePath && !options.imageUrl) {
    throw new Error("provide --image PATH or --url URL.");
  }

  const body = {
    id: canvasId,
    sourceSessionId: sessionId,
    sourceAgentId: options.agentId,
    title: options.title || path.basename(options.imagePath || options.imageUrl) || "Agent canvas",
    caption: options.caption,
    alt: options.alt,
    href: options.href,
    imagePath: options.imagePath,
    imageUrl: options.imageUrl,
  };

  const payload = await fetchJsonOrThrow(`${agentTownApi}/canvases`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify(body),
  });

  if (options.json) {
    process.stdout.write(`${JSON.stringify(payload, null, 2)}\n`);
    return;
  }

  process.stdout.write(`canvas ${payload.canvas?.id || canvasId}: ${payload.canvas?.title || body.title}\n`);
}

void main().catch((error) => {
  process.stderr.write(`vr-agent-canvas: ${error.message}\n`);
  process.exit(1);
});
