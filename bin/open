#!/usr/bin/env bash
set -euo pipefail

REAL_OPEN="/usr/bin/open"
ARGS="$*"

if printf '%s' "$ARGS" | /usr/bin/grep -Eqi 'https?://(127\.0\.0\.1|localhost|0\.0\.0\.0)'; then
  printf '[vibe-research] Use vr-playwright open <port-or-url>, vr-playwright snapshot, and vr-playwright screenshot instead of open for localhost UI inspection. Fall back to vr-browser only if vr-playwright fails for a concrete reason.\n' >&2
  exit 64
fi

exec "$REAL_OPEN" "$@"
