#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WRAPPER_PATH="$SCRIPT_DIR/openclaw"
MIN_NODE_MAJOR="${OPENCLAW_MIN_NODE_MAJOR:-22}"

canonical_path() {
  local target dir base
  target="$1"
  dir="$(cd "$(dirname "$target")" 2>/dev/null && pwd -P)" || return 1
  base="$(basename "$target")"
  printf '%s/%s\n' "$dir" "$base"
}

is_wrapper_path() {
  local candidate wrapper_real candidate_real
  candidate="$1"
  wrapper_real="$(canonical_path "$WRAPPER_PATH" 2>/dev/null || printf '%s\n' "$WRAPPER_PATH")"
  candidate_real="$(canonical_path "$candidate" 2>/dev/null || printf '%s\n' "$candidate")"
  [ "$candidate_real" = "$wrapper_real" ]
}

is_supported_node() {
  local candidate
  candidate="$1"
  if [ ! -x "$candidate" ]; then
    return 1
  fi

  "$candidate" -e 'const major = Number(process.versions.node.split(".")[0]); process.exit(major >= Number(process.env.OPENCLAW_MIN_NODE_MAJOR || 22) ? 0 : 1);' >/dev/null 2>&1
}

find_supported_node() {
  local candidate dir

  for candidate in \
    "${OPENCLAW_NODE:-}" \
    "${VIBE_RESEARCH_OPENCLAW_NODE:-}" \
    "${REMOTE_VIBES_OPENCLAW_NODE:-}" \
    /opt/homebrew/bin/node \
    /usr/local/bin/node \
    "${HOME:-}/.local/bin/node" \
    "$(command -v node 2>/dev/null || true)"; do
    if [ -n "$candidate" ] && is_supported_node "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if [ -n "${PATH:-}" ]; then
    local old_ifs
    old_ifs="$IFS"
    IFS=:
    for dir in $PATH; do
      IFS="$old_ifs"
      candidate="$dir/node"
      if [ -n "$dir" ] && is_supported_node "$candidate"; then
        printf '%s\n' "$candidate"
        return 0
      fi
      IFS=:
    done
    IFS="$old_ifs"
  fi

  return 1
}

find_real_openclaw() {
  local candidate dir

  for candidate in \
    "${VIBE_RESEARCH_REAL_OPENCLAW_COMMAND:-}" \
    "${REMOTE_VIBES_REAL_OPENCLAW_COMMAND:-}" \
    "${OPENCLAW_COMMAND:-}" \
    "${HOME:-}/.local/bin/openclaw" \
    /opt/homebrew/bin/openclaw \
    /usr/local/bin/openclaw; do
    if [ -n "$candidate" ] && [ -x "$candidate" ] && ! is_wrapper_path "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if [ -n "${PATH:-}" ]; then
    local old_ifs
    old_ifs="$IFS"
    IFS=:
    for dir in $PATH; do
      IFS="$old_ifs"
      candidate="$dir/openclaw"
      if [ -n "$dir" ] && [ -x "$candidate" ] && ! is_wrapper_path "$candidate"; then
        printf '%s\n' "$candidate"
        return 0
      fi
      IFS=:
    done
    IFS="$old_ifs"
  fi

  return 1
}

move_path_dir_first() {
  local target entry next old_ifs
  target="$1"
  if [ -z "$target" ]; then
    return
  fi

  next="$target"
  old_ifs="$IFS"
  IFS=:
  for entry in ${PATH:-}; do
    IFS="$old_ifs"
    if [ -n "$entry" ] && [ "$entry" != "$target" ]; then
      next="$next:$entry"
    fi
    IFS=:
  done
  IFS="$old_ifs"
  PATH="$next"
}

REAL_OPENCLAW="$(find_real_openclaw || true)"
if [ -z "$REAL_OPENCLAW" ]; then
  printf '[vibe-research] Could not find the real openclaw executable for the wrapper.\n' >&2
  printf '[vibe-research] Install it with: npm install -g openclaw@latest\n' >&2
  exit 1
fi

NODE_BIN="$(find_supported_node || true)"
if [ -z "$NODE_BIN" ]; then
  printf '[vibe-research] OpenClaw requires Node >=%s, but no supported node executable was found.\n' "$MIN_NODE_MAJOR" >&2
  printf '[vibe-research] Install Node %s+ from Homebrew or https://nodejs.org/en/download, then retry.\n' "$MIN_NODE_MAJOR" >&2
  exit 1
fi

move_path_dir_first /usr/local/bin
move_path_dir_first /opt/homebrew/bin
move_path_dir_first "$(dirname "$NODE_BIN")"
export PATH

export VIBE_RESEARCH_PROVIDER="${VIBE_RESEARCH_PROVIDER:-openclaw}"
export REMOTE_VIBES_PROVIDER="${REMOTE_VIBES_PROVIDER:-openclaw}"

FIRST_LINE="$(sed -n '1p' "$REAL_OPENCLAW" 2>/dev/null || true)"
case "$FIRST_LINE" in
  *node* | *Node*)
    exec "$NODE_BIN" "$REAL_OPENCLAW" "$@"
    ;;
  *)
    exec "$REAL_OPENCLAW" "$@"
    ;;
esac
