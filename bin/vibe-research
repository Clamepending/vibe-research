#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[vibe-research] %s\n' "$*"
}

fail() {
  printf '[vibe-research] %s\n' "$*" >&2
  exit 1
}

resolve_script_dir() {
  local source dir target
  source="${BASH_SOURCE[0]}"

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    target="$(readlink "$source")"
    case "$target" in
      /*)
        source="$target"
        ;;
      *)
        source="$dir/$target"
        ;;
    esac
  done

  cd -P "$(dirname "$source")" && pwd
}

resolve_app_dir() {
  local script_dir configured_dir
  script_dir="$(resolve_script_dir)"
  configured_dir="${VIBE_RESEARCH_HOME:-${REMOTE_VIBES_HOME:-}}"

  if [ -n "$configured_dir" ]; then
    printf '%s\n' "$configured_dir"
    return
  fi

  if [ -f "$script_dir/../start.sh" ]; then
    (cd "$script_dir/.." && pwd -P)
    return
  fi

  printf '%s\n' "$HOME/.vibe-research/app"
}

resolve_state_dir() {
  printf '%s\n' "${VIBE_RESEARCH_STATE_DIR:-${REMOTE_VIBES_STATE_DIR:-$HOME/.vibe-research}}"
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

is_linux() {
  [ "$(uname -s 2>/dev/null || true)" = "Linux" ]
}

is_root() {
  [ "$(id -u)" -eq 0 ]
}

try_run_as_root() {
  if is_root; then
    "$@"
    return
  fi

  if has_command sudo; then
    sudo "$@"
    return
  fi

  return 1
}

canonical_path() {
  local target dir base
  target="$1"

  if [ -d "$target" ]; then
    (cd -P "$target" && pwd)
    return
  fi

  dir="$(dirname "$target")"
  base="$(basename "$target")"
  if [ -d "$dir" ]; then
    printf '%s/%s\n' "$(cd -P "$dir" && pwd)" "$base"
    return
  fi

  printf '%s\n' "$target"
}

absolute_link_target() {
  local link_path link_target link_dir
  link_path="$1"
  link_target="$(readlink "$link_path" 2>/dev/null || true)"
  if [ -z "$link_target" ]; then
    return 1
  fi

  case "$link_target" in
    /*)
      printf '%s\n' "$link_target"
      ;;
    *)
      link_dir="$(dirname "$link_path")"
      printf '%s/%s\n' "$(cd -P "$link_dir" && pwd)" "$link_target"
      ;;
  esac
}

same_path() {
  [ "$(canonical_path "$1")" = "$(canonical_path "$2")" ]
}

remove_file_path() {
  local target="$1"

  if [ ! -e "$target" ] && [ ! -L "$target" ]; then
    return 0
  fi

  rm -f "$target" 2>/dev/null || try_run_as_root rm -f "$target"
}

remove_dir_path() {
  local target="$1"

  if [ ! -e "$target" ]; then
    return 0
  fi

  rm -rf "$target" 2>/dev/null || try_run_as_root rm -rf "$target"
}

dangerous_remove_dir() {
  local target
  target="$(canonical_path "$1")"

  case "$target" in
    ""|"/"|"$HOME"|"/usr"|"/usr/local"|"/opt"|"/etc"|"/var"|"/tmp"|"/private/tmp")
      return 0
      ;;
  esac

  return 1
}

looks_like_vibe_research_checkout() {
  local target="$1"

  [ -d "$target" ] \
    && [ -f "$target/start.sh" ] \
    && [ -f "$target/package.json" ] \
    && [ -f "$target/bin/vibe-research" ]
}

read_pid_file() {
  local pid_file="$1"
  local pid

  if [ ! -f "$pid_file" ]; then
    return 1
  fi

  pid="$(tr -d '[:space:]' <"$pid_file" 2>/dev/null || true)"
  if [ -z "$pid" ]; then
    return 1
  fi

  printf '%s\n' "$pid"
}

is_pid_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

looks_like_vibe_research_server() {
  local pid="$1"
  local command
  command="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  case "$command" in
    *"node src/server.js"*) return 0 ;;
    *"vibe-research"*"/src/server.js"*) return 0 ;;
    *"remote-vibes"*"/src/server.js"*) return 0 ;;
    *) return 1 ;;
  esac
}

wait_for_pid_exit() {
  local pid attempt
  pid="$1"
  for attempt in $(seq 1 50); do
    if ! is_pid_running "$pid"; then
      return 0
    fi
    sleep 0.2
  done
  return 1
}

stop_pid_with_grace() {
  local pid label
  pid="$1"
  label="${2:-server}"

  if ! is_pid_running "$pid"; then
    return
  fi

  log "Stopping Vibe Research $label (pid $pid)"
  kill "$pid" >/dev/null 2>&1 || true

  if wait_for_pid_exit "$pid"; then
    return
  fi

  log "$label pid $pid did not stop in time, sending SIGKILL"
  kill -9 "$pid" >/dev/null 2>&1 || true
  wait_for_pid_exit "$pid" || true
}

# List server pids on this host that look like Vibe Research / Remote Vibes:
# checks the full command line for `node ... src/server.js` invocations so we
# catch stragglers that the pid file no longer points at.
collect_orphan_server_pids() {
  local user pid
  user="$(id -un 2>/dev/null || true)"
  if [ -z "$user" ]; then
    return
  fi

  # `pgrep -f` matches against the full command line including args; `-u` keeps
  # us from ever touching another user's node processes. We deliberately match
  # broadly here — `looks_like_vibe_research_server` is the strict filter
  # applied downstream before we kill anything.
  if has_command pgrep; then
    pgrep -u "$user" -f 'node.*src/server\.js' 2>/dev/null | tr '\n' ' '
    return
  fi

  # Fallback: ps-based scan.
  ps -eo pid=,user=,command= 2>/dev/null | while read -r pid p_user rest; do
    [ "$p_user" = "$user" ] || continue
    case "$rest" in
      *"node "*"src/server.js"*) printf '%s ' "$pid" ;;
    esac
  done
}

# Kill tmux sessions whose names start with the managed prefix. The server
# spawns sessions named `vibe-research-<sessionId>` (or `remote-vibes-<id>` on
# legacy installs) — those reference paths under the now-removed app/state dir
# and serve no purpose after uninstall.
stop_managed_tmux_sessions() {
  if ! has_command tmux; then
    return
  fi

  local session prefixes prefix
  prefixes="vibe-research- remote-vibes-"

  # `tmux list-sessions` exits non-zero with no server running; that's fine.
  for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null); do
    for prefix in $prefixes; do
      case "$session" in
        "${prefix}"*)
          log "Killing managed tmux session: $session"
          tmux kill-session -t "$session" 2>/dev/null || true
          break
          ;;
      esac
    done
  done
}

stop_managed_server() {
  local state_dir pid_file pid orphan_pids orphan_pid
  state_dir="$1"
  pid_file="$state_dir/server.pid"

  if pid="$(read_pid_file "$pid_file")"; then
    if is_pid_running "$pid"; then
      if looks_like_vibe_research_server "$pid"; then
        stop_pid_with_grace "$pid" "server"
      else
        log "Leaving pid $pid running because it does not look like a managed Vibe Research server."
      fi
    fi
  fi
  rm -f "$pid_file" 2>/dev/null || true

  # Mop up any orphan server processes the pid file did not know about.
  orphan_pids="$(collect_orphan_server_pids)"
  for orphan_pid in $orphan_pids; do
    [ -n "$orphan_pid" ] || continue
    if ! is_pid_running "$orphan_pid"; then
      continue
    fi
    if looks_like_vibe_research_server "$orphan_pid"; then
      stop_pid_with_grace "$orphan_pid" "orphan server"
    fi
  done

  stop_managed_tmux_sessions
}

uninstall_one_systemd_service() {
  local service_name service_dir service_file service_exists
  service_name="$1"
  service_dir="$2"
  service_file="$service_dir/${service_name}.service"
  service_exists=0

  if try_run_as_root systemctl cat "${service_name}.service" >/dev/null 2>&1; then
    service_exists=1
  elif [ -e "$service_file" ]; then
    service_exists=1
  fi

  if [ "$service_exists" != "1" ]; then
    return
  fi

  log "Disabling systemd service ${service_name}.service"
  try_run_as_root systemctl stop "${service_name}.service" >/dev/null 2>&1 || log "Could not stop ${service_name}.service; continuing."
  try_run_as_root systemctl disable "${service_name}.service" >/dev/null 2>&1 || log "Could not disable ${service_name}.service; continuing."

  if [ -e "$service_file" ]; then
    log "Removing systemd unit: $service_file"
    remove_file_path "$service_file" || log "Could not remove $service_file"
  fi

  try_run_as_root systemctl daemon-reload >/dev/null 2>&1 || log "Could not reload systemd; continuing."
  try_run_as_root systemctl reset-failed "${service_name}.service" >/dev/null 2>&1 || true
}

uninstall_systemd_service() {
  local primary_name service_dir name seen
  primary_name="${VIBE_RESEARCH_SERVICE_NAME:-${REMOTE_VIBES_SERVICE_NAME:-vibe-research}}"
  service_dir="${VIBE_RESEARCH_SYSTEMD_SERVICE_DIR:-${REMOTE_VIBES_SYSTEMD_SERVICE_DIR:-/etc/systemd/system}}"

  if [ "${VIBE_RESEARCH_UNINSTALL_SERVICE:-${REMOTE_VIBES_UNINSTALL_SERVICE:-1}}" = "0" ]; then
    return
  fi

  if ! is_linux || ! has_command systemctl; then
    return
  fi

  # Clean up the configured service name plus the legacy "remote-vibes" name
  # left behind by older installs that ran before the rename.
  seen=""
  for name in "$primary_name" vibe-research remote-vibes; do
    [ -n "$name" ] || continue
    case ":$seen:" in
      *":$name:"*) continue ;;
    esac
    seen="$seen:$name"
    uninstall_one_systemd_service "$name" "$service_dir"
  done
}

remove_launcher_commands() {
  local app_dir launcher_source command_path candidate link_target canonical_source canonical_target
  local candidates=()
  app_dir="$1"
  launcher_source="$app_dir/bin/vibe-research"
  canonical_source="$(canonical_path "$launcher_source")"

  if command_path="$(command -v vibe-research 2>/dev/null)" && [ -n "$command_path" ]; then
    candidates+=("$command_path")
  fi

  case "${0:-}" in
    */*) candidates+=("$0") ;;
  esac

  if [ -n "${VIBE_RESEARCH_BIN_DIR:-${REMOTE_VIBES_BIN_DIR:-}}" ]; then
    candidates+=("${VIBE_RESEARCH_BIN_DIR:-${REMOTE_VIBES_BIN_DIR:-}}/vibe-research")
  fi

  candidates+=(
    "$HOME/.local/bin/vibe-research"
    "$HOME/bin/vibe-research"
    "/usr/local/bin/vibe-research"
    "/opt/homebrew/bin/vibe-research"
  )

  for candidate in "${candidates[@]}"; do
    [ -n "$candidate" ] || continue

    if [ ! -L "$candidate" ]; then
      if [ -e "$candidate" ] && ! same_path "$candidate" "$launcher_source"; then
        log "Leaving non-symlink command in place: $candidate"
      fi
      continue
    fi

    if ! link_target="$(absolute_link_target "$candidate")"; then
      continue
    fi

    canonical_target="$(canonical_path "$link_target")"
    if [ "$canonical_target" != "$canonical_source" ]; then
      log "Leaving unrelated vibe-research symlink in place: $candidate"
      continue
    fi

    log "Removing terminal command: $candidate"
    remove_file_path "$candidate" || log "Could not remove $candidate"
  done
}

confirm_uninstall() {
  local app_dir state_dir purge answer
  app_dir="$1"
  state_dir="$2"
  purge="$3"

  if [ "${VIBE_RESEARCH_UNINSTALL_YES:-0}" = "1" ]; then
    return
  fi

  log "This will uninstall Vibe Research from this system."
  log "App checkout: $app_dir"
  log "State directory: $state_dir ($(if [ "$purge" = "1" ]; then printf 'will remove'; else printf 'will keep'; fi))"

  if [ ! -t 0 ]; then
    fail "Refusing to uninstall without --yes in a non-interactive shell."
  fi

  printf 'Uninstall Vibe Research? [y/N] '
  read -r answer
  case "$answer" in
    y|Y|yes|YES|Yes)
      ;;
    *)
      fail "Uninstall cancelled."
      ;;
  esac
}

remove_app_checkout() {
  local app_dir="$1"

  if [ ! -e "$app_dir" ]; then
    log "No app checkout found at $app_dir"
    return
  fi

  if dangerous_remove_dir "$app_dir"; then
    fail "Refusing to remove unsafe app directory: $app_dir"
  fi

  if ! looks_like_vibe_research_checkout "$app_dir"; then
    fail "Refusing to remove $app_dir because it does not look like a Vibe Research app checkout."
  fi

  log "Removing app checkout: $app_dir"
  remove_dir_path "$app_dir" || fail "Could not remove app checkout: $app_dir"
}

remove_state_dir_if_requested() {
  local state_dir="$1"
  local purge="$2"

  if [ "$purge" != "1" ]; then
    if [ -e "$state_dir" ]; then
      log "Keeping local state: $state_dir (use --purge to remove it)."
    fi
    return
  fi

  if [ ! -e "$state_dir" ]; then
    return
  fi

  if dangerous_remove_dir "$state_dir"; then
    fail "Refusing to remove unsafe state directory: $state_dir"
  fi

  log "Removing local state: $state_dir"
  remove_dir_path "$state_dir" || fail "Could not remove state directory: $state_dir"
}

uninstall_vibe_research() {
  local app_dir state_dir purge
  app_dir="$(resolve_app_dir)"
  state_dir="$(resolve_state_dir)"
  purge="$1"

  confirm_uninstall "$app_dir" "$state_dir" "$purge"
  uninstall_systemd_service
  stop_managed_server "$state_dir"
  remove_launcher_commands "$app_dir"
  remove_app_checkout "$app_dir"
  remove_state_dir_if_requested "$state_dir" "$purge"
  log "Uninstall complete."
}

browser_url() {
  local host port browser_host
  host="${VIBE_RESEARCH_HOST:-${REMOTE_VIBES_HOST:-0.0.0.0}}"
  port="${VIBE_RESEARCH_PORT:-${REMOTE_VIBES_PORT:-4826}}"

  case "$host" in
    ""|0.0.0.0|127.0.0.1|localhost|::|::0|[::]|::1|[::1])
      browser_host="localhost"
      ;;
    *:*)
      case "$host" in
        [*]) browser_host="$host" ;;
        *) browser_host="[$host]" ;;
      esac
      ;;
    *)
      browser_host="$host"
      ;;
  esac

  printf 'http://%s:%s/\n' "$browser_host" "$port"
}

open_browser() {
  local url="$1"
  local open_command

  if [ "${VIBE_RESEARCH_OPEN_BROWSER:-${REMOTE_VIBES_OPEN_BROWSER:-1}}" = "0" ]; then
    log "Open Vibe Research: $url"
    return
  fi

  open_command="${VIBE_RESEARCH_OPEN_COMMAND:-${REMOTE_VIBES_OPEN_COMMAND:-}}"
  if [ -n "$open_command" ]; then
    "$open_command" "$url" >/dev/null 2>&1 || {
      log "Could not open browser automatically. Open: $url"
      return
    }
    log "Opened Vibe Research: $url"
    return
  fi

  if [ "$(uname -s 2>/dev/null || true)" = "Darwin" ] && [ -x /usr/bin/open ]; then
    /usr/bin/open "$url" >/dev/null 2>&1 || log "Could not open browser automatically. Open: $url"
    return
  fi

  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 || log "Could not open browser automatically. Open: $url"
    return
  fi

  if command -v wslview >/dev/null 2>&1; then
    wslview "$url" >/dev/null 2>&1 || log "Could not open browser automatically. Open: $url"
    return
  fi

  if command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -NoProfile -Command 'Start-Process -FilePath $args[0]' "$url" >/dev/null 2>&1 || log "Could not open browser automatically. Open: $url"
    return
  fi

  log "Open Vibe Research: $url"
}

print_usage() {
  cat <<'EOF'
Usage:
  vibe-research [--no-browser] [--url]
  vibe-research uninstall [--yes] [--purge]

Launch Vibe Research if needed and open the local UI in your browser.

Options:
  --no-browser   Start or reuse the server without opening a browser.
  --url          Print the local browser URL and exit.
  -h, --help     Show this help.

Uninstall:
  uninstall      Stop Vibe Research and remove the terminal command and app checkout.
  --yes          Do not prompt for confirmation.
  --purge        Also remove local state under VIBE_RESEARCH_STATE_DIR (default ~/.vibe-research).
EOF
}

command_name="launch"
open_after_start=1
print_url_only=0
uninstall_purge=0

case "${1:-}" in
  uninstall)
    command_name="uninstall"
    shift
    ;;
esac

while [ "$#" -gt 0 ]; do
  if [ "$command_name" = "uninstall" ]; then
    case "$1" in
      --yes|-y)
        VIBE_RESEARCH_UNINSTALL_YES=1
        ;;
      --purge)
        uninstall_purge=1
        ;;
      -h|--help)
        print_usage
        exit 0
        ;;
      *)
        fail "Unknown uninstall option: $1"
        ;;
    esac
  else
    case "$1" in
      --no-browser)
        open_after_start=0
        ;;
      --url)
        print_url_only=1
        ;;
      -h|--help)
        print_usage
        exit 0
        ;;
      *)
        fail "Unknown option: $1"
        ;;
    esac
  fi
  shift
done

if [ "$command_name" = "uninstall" ]; then
  uninstall_vibe_research "$uninstall_purge"
  exit 0
fi

url="$(browser_url)"
if [ "$print_url_only" = "1" ]; then
  printf '%s\n' "$url"
  exit 0
fi

app_dir="$(resolve_app_dir)"
if [ ! -x "$app_dir/start.sh" ]; then
  fail "Could not find Vibe Research at $app_dir. Re-run the installer, or set VIBE_RESEARCH_HOME to the app checkout."
fi

"$app_dir/start.sh"

if [ "$open_after_start" = "1" ]; then
  open_browser "$url"
else
  log "Open Vibe Research: $url"
fi
