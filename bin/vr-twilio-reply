#!/usr/bin/env node

import { readFile } from "node:fs/promises";
import path from "node:path";
import process from "node:process";

function printHelp() {
  process.stdout.write(`vr-twilio-reply

Send a plain-text SMS reply through the local Vibe Research Twilio building.

Usage:
  vr-twilio-reply --to <phone> [--message-sid <sid>] [--text <reply>]
  vr-twilio-reply --to <phone> [--message-sid <sid>] < reply.txt

Examples:
  vr-twilio-reply --to +15551234567 --message-sid SM123 <<'EOF'
  Thanks, I will take a look.
  EOF
`);
}

function parseArgs(argv) {
  const options = {
    messageSid: "",
    text: "",
    to: "",
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    const readValue = (name) => {
      const inlinePrefix = `${name}=`;
      if (arg.startsWith(inlinePrefix)) {
        return arg.slice(inlinePrefix.length);
      }
      index += 1;
      return argv[index] || "";
    };

    if (arg === "--help" || arg === "-h") {
      options.help = true;
      continue;
    }

    if (arg === "--to" || arg.startsWith("--to=")) {
      options.to = readValue("--to");
      continue;
    }

    if (arg === "--message-sid" || arg.startsWith("--message-sid=")) {
      options.messageSid = readValue("--message-sid");
      continue;
    }

    if (arg === "--text" || arg.startsWith("--text=")) {
      options.text = readValue("--text");
      continue;
    }

    throw new Error(`unknown argument: ${arg}`);
  }

  return options;
}

async function readStdin() {
  if (process.stdin.isTTY) {
    return "";
  }

  const chunks = [];
  for await (const chunk of process.stdin) {
    chunks.push(Buffer.from(chunk));
  }
  return Buffer.concat(chunks).toString("utf8");
}

async function readServerInfo(rootDir) {
  const raw = await readFile(path.join(rootDir, "server.json"), "utf8");
  return JSON.parse(raw);
}

async function main() {
  let options;
  try {
    options = parseArgs(process.argv.slice(2));
  } catch (error) {
    process.stderr.write(`vr-twilio-reply: ${error.message}\n`);
    process.exit(1);
  }

  if (options.help) {
    printHelp();
    return;
  }

  if (!options.to) {
    process.stderr.write("vr-twilio-reply: --to is required.\n");
    process.exit(1);
  }

  const text = options.text || (await readStdin()).trim();
  if (!text) {
    process.stderr.write("vr-twilio-reply: provide reply text via --text or stdin.\n");
    process.exit(1);
  }

  const rootDir = String(process.env.VIBE_RESEARCH_ROOT || process.env.REMOTE_VIBES_ROOT || "").trim();
  if (!rootDir) {
    process.stderr.write("vr-twilio-reply: VIBE_RESEARCH_ROOT is not set.\n");
    process.exit(1);
  }

  let serverInfo;
  try {
    serverInfo = await readServerInfo(rootDir);
  } catch (error) {
    process.stderr.write(`vr-twilio-reply: could not read Vibe Research server info (${error.message}).\n`);
    process.exit(1);
  }

  const baseUrl = String(serverInfo?.helperBaseUrl || "").trim();
  const token = String(serverInfo?.twilioReplyToken || "").trim();
  if (!baseUrl || !token) {
    process.stderr.write("vr-twilio-reply: Twilio reply helper is not available from this session.\n");
    process.exit(1);
  }

  const response = await fetch(`${baseUrl}/api/twilio/reply`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-vibe-research-twilio-token": token,
    },
    body: JSON.stringify({
      messageSid: options.messageSid,
      text,
      to: options.to,
    }),
  });
  const payload = await response.json().catch(() => ({}));

  if (!response.ok) {
    process.stderr.write(`vr-twilio-reply: ${payload.error || `request failed (${response.status})`}\n`);
    process.exit(1);
  }

  process.stdout.write(`Twilio SMS reply sent: ${payload.reply?.sid || "ok"}\n`);
}

void main();
