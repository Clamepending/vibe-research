#!/usr/bin/env node
// vr-rl-tuner — bootstrap a Vibe Research project that an existing
// coding agent (Claude Code, Codex, etc.) can take over via the
// rl-sweep-tuner skill.
//
// This used to spawn a separate agent. That was the wrong shape: the
// coding agent that's already running in the user's session IS the
// tuner — it just needs the right project + context loaded. So this
// command only:
//
//   1. Bootstraps projects/<name>/ via createProject() (README + paper
//      + results/ + figures/).
//   2. Writes projects/<name>/kickoff.json with the goal + budget +
//      target repo path so the coding agent has all the human-supplied
//      context in one place.
//   3. Prints a one-liner the user can hand to their coding agent
//      ("/rl-sweep-tuner" + project name) so it loads the skill and
//      starts the loop.
//
// Usage:
//   vr-rl-tuner --repo /path/to/grad-student-repo \
//               --goal "find best LR/batch combo for PPO on Atari" \
//               --budget "20 GPU-hours, $50" \
//               --library /path/to/lab-library

import path from "node:path";
import process from "node:process";
import { writeFile, stat } from "node:fs/promises";

import { createProject, DEFAULT_PROJECT_NAME_PATTERN } from "../src/research/init.js";

function printHelp() {
  process.stdout.write(`vr-rl-tuner — bootstrap a tuning project for the coding agent

Usage:
  vr-rl-tuner --repo <path> --goal <text> [options]

Required:
  --repo <path>            Absolute path to the project's code repo
  --goal <text>            One-paragraph what the agent should optimize for

Optional:
  --library <path>         Library root (default: cwd)
  --name <slug>            Project slug under projects/ (default: derived from --repo)
  --budget <text>          Free-form budget statement (e.g. "20 GPU-hours, $50")
  --base <pairs>           Comma-separated base config the sweeps anchor on
  --json                   Emit machine-readable summary on stdout
  --force                  Overwrite an existing project dir
  --help, -h               Show this message

After this command finishes, tell your existing coding agent:

  Use the rl-sweep-tuner skill to take over projects/<name>.

The agent will load skills/rl-sweep-tuner/SKILL.md, read kickoff.json,
plan + run the first move, and update the leaderboard / paper /
runs.tsv autonomously across moves.
`);
}

function parseArgs(argv) {
  const opts = {
    repo: "",
    goal: "",
    library: process.cwd(),
    name: "",
    budget: "",
    base: "",
    json: false,
    force: false,
    help: false,
  };
  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--help" || arg === "-h") { opts.help = true; continue; }
    if (arg === "--json") { opts.json = true; continue; }
    if (arg === "--force") { opts.force = true; continue; }
    if (arg === "--repo") { opts.repo = argv[++i] || ""; continue; }
    if (arg === "--goal") { opts.goal = argv[++i] || ""; continue; }
    if (arg === "--library") { opts.library = argv[++i] || ""; continue; }
    if (arg === "--name") { opts.name = argv[++i] || ""; continue; }
    if (arg === "--budget") { opts.budget = argv[++i] || ""; continue; }
    if (arg === "--base") { opts.base = argv[++i] || ""; continue; }
    if (arg.startsWith("--")) throw new Error(`unknown flag: ${arg}`);
    throw new Error(`unexpected positional arg: ${arg}`);
  }
  return opts;
}

function deriveProjectName(repoPath) {
  const base = path.basename(path.resolve(repoPath));
  const slug = base.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
  return slug || "rl-sweep";
}

async function pathExists(p) {
  try { await stat(p); return true; } catch { return false; }
}

async function main() {
  let opts;
  try { opts = parseArgs(process.argv.slice(2)); }
  catch (err) {
    process.stderr.write(`${err.message}\n\n`);
    printHelp();
    process.exit(2);
  }
  if (opts.help) { printHelp(); process.exit(0); }

  const errors = [];
  if (!opts.repo) errors.push("--repo is required");
  if (!opts.goal) errors.push("--goal is required");
  const repo = opts.repo ? path.resolve(opts.repo) : "";
  if (repo && !(await pathExists(repo))) errors.push(`--repo path not found: ${repo}`);
  if (errors.length) {
    for (const e of errors) process.stderr.write(`${e}\n`);
    process.exit(2);
  }

  const library = path.resolve(opts.library);
  const projectsDir = path.join(library, "projects");
  const projectName = opts.name || deriveProjectName(repo);
  if (!DEFAULT_PROJECT_NAME_PATTERN.test(projectName)) {
    process.stderr.write(`derived project name "${projectName}" must match ${DEFAULT_PROJECT_NAME_PATTERN}; pass --name explicitly\n`);
    process.exit(2);
  }

  let initResult;
  try {
    initResult = await createProject({
      projectsDir,
      name: projectName,
      goal: opts.goal,
      successCriteria: opts.budget ? [`stay within budget: ${opts.budget}`] : [],
      ranking: { kind: "quantitative", metric: "mean_return", direction: "higher" },
      queueRows: [],
      force: opts.force,
    });
  } catch (err) {
    process.stderr.write(`${err.message}\n`);
    process.exit(1);
  }

  const kickoff = {
    repo,
    goal: opts.goal,
    budget: opts.budget,
    base: opts.base,
    library,
    projectDir: initResult.projectDir,
    spawnedAt: new Date().toISOString(),
    spawnedBy: "vr-rl-tuner",
  };
  const kickoffPath = path.join(initResult.projectDir, "kickoff.json");
  await writeFile(kickoffPath, `${JSON.stringify(kickoff, null, 2)}\n`, "utf8");

  const summary = {
    projectDir: initResult.projectDir,
    kickoff: kickoffPath,
    repo,
    nextStep: `Tell your coding agent: "Use the rl-sweep-tuner skill to take over ${initResult.projectDir}."`,
    wrote: [...initResult.wrote, kickoffPath],
  };

  if (opts.json) {
    process.stdout.write(`${JSON.stringify(summary, null, 2)}\n`);
    process.exit(0);
  }

  process.stdout.write(`bootstrapped ${initResult.projectDir}\n`);
  process.stdout.write(`kickoff:    ${kickoffPath}\n`);
  process.stdout.write(`\nNext step: tell your coding agent to take over.\n\n`);
  process.stdout.write(`  Use the rl-sweep-tuner skill to take over ${initResult.projectDir}.\n\n`);
  process.stdout.write(`The agent will load skills/rl-sweep-tuner/SKILL.md, read kickoff.json,\n`);
  process.stdout.write(`plan + run moves, and update the leaderboard / paper / runs.tsv autonomously.\n`);
  process.exit(0);
}

main();
