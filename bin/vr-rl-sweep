#!/usr/bin/env node
// vr-rl-sweep — plan an RL hyperparameter / architecture / data-mixture
// sweep in the Vibe Research project shape, with the friend-of-the-house
// Google-Doc-row format as the on-disk artifact.
//
// V1 ships PLAN ONLY. Execution + wandb integration land in a follow-up.
// The plan output is good enough on Day One: open runs.tsv in a
// spreadsheet, paste into Google Docs, do whatever you do.
//
// Usage:
//   vr-rl-sweep init lr-bs-grid \
//     --base lr=1e-3,batch=256,frames=4 \
//     --sweep lr=[1e-4,1e-3,1e-2] --sweep batch=[256,512] \
//     --seeds 3 \
//     --hypothesis "lr/batch interaction"
//
// What it does:
//   1. Calls vr-research-init (or its module form) to bootstrap
//      projects/<name>/ with README + paper.md + results/ + figures/.
//   2. Resolves the Cartesian product of sweep dimensions × seeds.
//   3. Writes projects/<name>/runs.tsv with one row per (cell, seed)
//      in the friend's familiar format:
//         started_at, group, name, commit, hypothesis,
//         mean_return, std_return, wandb_url, status, config

import path from "node:path";
import process from "node:process";
import { execSync } from "node:child_process";
import { writeFile } from "node:fs/promises";

import { createProject } from "../src/research/init.js";
import {
  parseSweepEntry,
  planSweep,
  renderRunsTsv,
} from "../src/research/sweep.js";
import { runPlannedRows, parseRunsTsv } from "../src/research/sweep-runner.js";
import { pullWandbMetrics } from "../src/research/wandb-pull.js";
import { readFile } from "node:fs/promises";

function printHelp() {
  process.stdout.write(`vr-rl-sweep <subcommand> [options]

Subcommands:
  init <name>     Plan a sweep. If projects/<name>/ doesn't exist yet,
                  bootstrap the project (README + paper + dirs) and write
                  runs.tsv at the top level. If it DOES exist and a
                  --sweep-name <slug> is given, write
                  projects/<name>/runs/<slug>.tsv instead — the
                  multi-move-in-one-project pattern (one project per
                  question, many sweeps inside it). Without --sweep-name
                  on an existing project, --force is required.
  run <name>      Walk planned rows in a runs.tsv, spawn each one's
                  launcher, capture metric, update the row in-place.
                  Reads projects/<name>/runs/<slug>.tsv when --sweep-name
                  <slug> is given, else projects/<name>/runs.tsv.
  summary <name>  Read the runs.tsv (or runs/<slug>.tsv with
                  --sweep-name) and print: status counts, per-cell
                  mean ± std across seeds, and the top-N cells. Useful
                  for the agent to check sweep state without parsing
                  the TSV by hand. --json prints full structured data.
  wandb-pull <name> Back-fill mean_return from wandb summaries for
                  rows whose launcher logged to wandb but didn't print
                  the metric to stdout. Reads each row's wandb_url,
                  GraphQL-fetches the run's summaryMetrics, writes
                  back into mean_return. Idempotent (skips rows
                  already filled unless --overwrite).

Init options:
  --base <pairs>           Comma-separated base config: key=value,...
  --sweep <key=spec>       Sweep dimension. Repeatable. Spec forms:
                             key=val
                             key=[v1,v2,v3]
                             key=v1,v2,v3
                             key=range(a,b,step)        (numeric range)
                             key=logspace(a,b,n)        (n log-spaced points)
  --sweep-name <slug>      Write runs/<slug>.tsv inside an existing
                           project instead of bootstrapping a new one.
                           Use this for follow-up sweeps under one
                           question.
  --seeds <n>              Number of seeds per cell (default 1).
  --hypothesis <text>      One-line pre-launch hypothesis.
  --library <path>         Library root (defaults to cwd).
  --commit <sha>           Commit SHA to record (defaults to git HEAD of cwd).
  --force                  Overwrite an existing project dir / sweep.

Run options:
  --library <path>         Library root (defaults to cwd).
  --sweep-name <slug>      Read projects/<name>/runs/<slug>.tsv instead
                           of the top-level runs.tsv.
  --launcher <template>    Shell command template; \${key} is substituted
                           from the row's resolved config. Default infers
                           "python train.py --<key>=<value> --seed=<N>".
  --metric <regex>         Capture-group-1 of the first match in stdout
                           is parsed as mean_return. Default matches
                           "final_return: 1.23" or "mean_return=1.23".
  --max-rows <N>           Stop after launching N rows (useful for dry runs).
  --timeout-sec <N>        Per-row hard kill (default 1800).
  --cwd <path>             Working dir for the launcher (default cwd).

Summary options:
  --library <path>         Library root (defaults to cwd).
  --sweep-name <slug>      Read projects/<name>/runs/<slug>.tsv instead
                           of the top-level runs.tsv.
  --top <n>                Show the top N cells (default 5).
  --direction-lower        Sort cells by ascending mean_return (use when
                           the project's metric is "lower is better").

Wandb-pull options:
  --library <path>         Library root (defaults to cwd).
  --sweep-name <slug>      Read projects/<name>/runs/<slug>.tsv.
  --metric <key>           Wandb summary key to read (default "mean_return").
  --overwrite              Refill rows that already have a mean_return
                           value. Default: skip those rows.

Common:
  --json                   Emit machine-readable summary on stdout.
`);
}

function parseArgs(argv) {
  const options = {
    subcommand: "",
    name: "",
    base: "",
    sweepSpecs: [],
    seeds: 1,
    hypothesis: "",
    library: process.cwd(),
    commit: "",
    force: false,
    json: false,
    help: false,
    launcher: "",
    metric: "",
    maxRows: undefined,
    timeoutSec: undefined,
    runCwd: "",
    sweepName: "",
    top: undefined,
    directionLower: false,
    overwrite: false,
  };
  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--help" || arg === "-h") { options.help = true; continue; }
    if (arg === "--force") { options.force = true; continue; }
    if (arg === "--json") { options.json = true; continue; }
    if (arg === "--base") { options.base = argv[++i] || ""; continue; }
    if (arg === "--sweep") { options.sweepSpecs.push(argv[++i] || ""); continue; }
    if (arg === "--seeds") { options.seeds = Number(argv[++i] || "1"); continue; }
    if (arg === "--hypothesis") { options.hypothesis = argv[++i] || ""; continue; }
    if (arg === "--library") { options.library = argv[++i] || ""; continue; }
    if (arg === "--commit") { options.commit = argv[++i] || ""; continue; }
    if (arg === "--launcher") { options.launcher = argv[++i] || ""; continue; }
    if (arg === "--metric") { options.metric = argv[++i] || ""; continue; }
    if (arg === "--max-rows") { options.maxRows = Number(argv[++i] || "0"); continue; }
    if (arg === "--timeout-sec") { options.timeoutSec = Number(argv[++i] || "0"); continue; }
    if (arg === "--cwd") { options.runCwd = argv[++i] || ""; continue; }
    if (arg === "--sweep-name") { options.sweepName = argv[++i] || ""; continue; }
    if (arg === "--top") { options.top = Number(argv[++i] || "5"); continue; }
    if (arg === "--direction-lower") { options.directionLower = true; continue; }
    if (arg === "--overwrite") { options.overwrite = true; continue; }
    if (arg.startsWith("--")) throw new Error(`unknown flag: ${arg}`);
    if (!options.subcommand) { options.subcommand = arg; continue; }
    if (!options.name) { options.name = arg; continue; }
    throw new Error(`unexpected positional arg: ${arg}`);
  }
  return options;
}

function parseBaseConfig(text) {
  const out = {};
  if (!text) return out;
  for (const part of text.split(",")) {
    const [k, ...rest] = part.split("=");
    if (!k || rest.length === 0) {
      throw new Error(`--base entry must be key=value; got "${part}"`);
    }
    out[k.trim()] = rest.join("=").trim();
  }
  return out;
}

function resolveSweep(specs) {
  const out = {};
  for (const spec of specs) {
    const { key, values } = parseSweepEntry(spec);
    if (Object.prototype.hasOwnProperty.call(out, key)) {
      throw new Error(`duplicate --sweep key: ${key}`);
    }
    out[key] = values;
  }
  return out;
}

function resolveCommit(explicit, library) {
  if (explicit) return explicit;
  try {
    return execSync("git -C " + JSON.stringify(library) + " rev-parse HEAD", {
      stdio: ["ignore", "pipe", "ignore"],
    }).toString().trim();
  } catch {
    return "";
  }
}

async function runInit(options) {
  if (!options.name) throw new Error("project name is required");
  const library = path.resolve(options.library);
  const projectsDir = path.join(library, "projects");
  const projectDir = path.join(projectsDir, options.name);

  const baseConfig = parseBaseConfig(options.base);
  const sweepMap = resolveSweep(options.sweepSpecs);
  const commit = resolveCommit(options.commit, library);

  // Two modes:
  //   1. --sweep-name <slug> + project EXISTS  → in-project sweep at
  //      runs/<slug>.tsv. The right shape for follow-up moves under one
  //      research question (one project, many sweeps).
  //   2. Otherwise → bootstrap a new project + write the top-level
  //      runs.tsv. Backwards-compatible with the original shape.
  const fs = await import("node:fs/promises");
  let projectExists = false;
  try { await fs.stat(projectDir); projectExists = true; } catch {}

  let projectDirOut = projectDir;
  let wrote = [];
  if (options.sweepName && projectExists) {
    // Make sure runs/ subdir exists.
    await fs.mkdir(path.join(projectDir, "runs"), { recursive: true });
  } else {
    // Bootstrap (or refuse if exists w/o --force).
    const initResult = await createProject({
      projectsDir,
      name: options.name,
      goal: options.hypothesis || "",
      successCriteria: [],
      ranking: { kind: "quantitative", metric: "mean_return", direction: "higher" },
      queueRows: [],
      force: options.force,
    });
    projectDirOut = initResult.projectDir;
    wrote = [...initResult.wrote];
  }

  // Build the sweep plan + write the right TSV path.
  const planName = options.sweepName || options.name;
  const plan = planSweep({
    name: planName,
    base: baseConfig,
    sweep: sweepMap,
    seeds: options.seeds,
    hypothesis: options.hypothesis,
    commit,
    now: () => new Date().toISOString(),
  });
  const tsvPath = options.sweepName
    ? path.join(projectDirOut, "runs", `${options.sweepName}.tsv`)
    : path.join(projectDirOut, "runs.tsv");
  await writeFile(tsvPath, renderRunsTsv(plan.rows), "utf8");

  return {
    projectDir: projectDirOut,
    runsTsv: tsvPath,
    sweepName: options.sweepName || null,
    cells: plan.rows.length / Math.max(1, options.seeds),
    seeds: options.seeds,
    totalRows: plan.rows.length,
    commit,
    hypothesis: options.hypothesis,
    sweepDimensions: Object.fromEntries(
      Object.entries(sweepMap).map(([k, v]) => [k, v.length]),
    ),
    wrote: [...wrote, tsvPath],
  };
}

async function runRun(options) {
  if (!options.name) throw new Error("project name is required");
  const library = path.resolve(options.library);
  const projectDir = path.join(library, "projects", options.name);
  const runsTsvPath = options.sweepName
    ? path.join(projectDir, "runs", `${options.sweepName}.tsv`)
    : path.join(projectDir, "runs.tsv");

  let metricPattern;
  if (options.metric) {
    try { metricPattern = new RegExp(options.metric); }
    catch (err) { throw new Error(`invalid --metric regex: ${err.message}`); }
  }

  const result = await runPlannedRows({
    runsTsvPath,
    launcherTemplate: options.launcher || null,
    metricPattern,
    timeoutSec: options.timeoutSec,
    maxRows: options.maxRows,
    cwd: options.runCwd ? path.resolve(options.runCwd) : undefined,
  });
  return {
    runsTsv: runsTsvPath,
    ran: result.ran,
    ok: result.ok,
    failed: result.failed,
    skipped: result.skipped,
  };
}

// Aggregate runs.tsv into per-cell stats. A "cell" is a row's name with
// the trailing `-seedN` suffix stripped — i.e. one row per (config, seed)
// collapses into one cell summarised across seeds.
function aggregateCells(rows, { directionHigher = true } = {}) {
  const groups = new Map();
  for (const row of rows) {
    const cellName = String(row.name || "").replace(/-seed\d+$/, "");
    if (!groups.has(cellName)) groups.set(cellName, []);
    groups.get(cellName).push(row);
  }
  const cells = [];
  for (const [name, members] of groups.entries()) {
    if (!name) continue;
    const numerics = members
      .map((r) => Number(r.mean_return))
      .filter((v) => Number.isFinite(v));
    const seeds = numerics.length;
    let mean = null;
    let std = null;
    if (seeds >= 1) {
      mean = numerics.reduce((a, b) => a + b, 0) / seeds;
      if (seeds >= 2) {
        const variance = numerics.reduce((a, b) => a + (b - mean) ** 2, 0) / seeds;
        std = Math.sqrt(variance);
      }
    }
    const wandbUrl = members.map((r) => r.wandb_url).find((u) => u && u.length > 0) || "";
    const hypothesis = members.map((r) => r.hypothesis).find((h) => h && h.length > 0) || "";
    cells.push({
      name,
      seeds,
      mean_return: mean,
      std_return: std,
      wandb_url: wandbUrl,
      hypothesis,
      statuses: members.reduce((acc, m) => {
        const s = String(m.status || "").trim() || "planned";
        acc[s] = (acc[s] || 0) + 1;
        return acc;
      }, {}),
    });
  }
  cells.sort((a, b) => {
    if (a.mean_return === null && b.mean_return === null) return 0;
    if (a.mean_return === null) return 1;
    if (b.mean_return === null) return -1;
    return directionHigher ? b.mean_return - a.mean_return : a.mean_return - b.mean_return;
  });
  return cells;
}

function tallyStatuses(rows) {
  const counts = {};
  for (const row of rows) {
    const s = String(row.status || "").trim() || "planned";
    counts[s] = (counts[s] || 0) + 1;
  }
  return counts;
}

async function runSummary(options) {
  if (!options.name) throw new Error("project name is required");
  const library = path.resolve(options.library);
  const projectDir = path.join(library, "projects", options.name);
  const runsTsvPath = options.sweepName
    ? path.join(projectDir, "runs", `${options.sweepName}.tsv`)
    : path.join(projectDir, "runs.tsv");

  let text;
  try { text = await readFile(runsTsvPath, "utf8"); }
  catch (err) {
    if (err.code === "ENOENT") throw new Error(`runs.tsv not found at ${runsTsvPath}`);
    throw err;
  }
  const { headers, rows } = parseRunsTsv(text);
  if (!headers.length) throw new Error(`runs.tsv at ${runsTsvPath} is empty / has no header`);

  const directionHigher = options.directionLower !== true;
  const statusCounts = tallyStatuses(rows);
  const cells = aggregateCells(rows, { directionHigher });
  const topN = Number.isFinite(options.top) && options.top > 0 ? options.top : 5;

  return {
    project: options.name,
    sweep: options.sweepName || null,
    runsTsv: runsTsvPath,
    totalRows: rows.length,
    statusCounts,
    cellCount: cells.length,
    topCells: cells.slice(0, topN),
    allCells: cells,
    direction: directionHigher ? "higher" : "lower",
  };
}

function formatSummaryText(s) {
  const lines = [];
  const sweepLabel = s.sweep ? `sweep: ${s.sweep}` : "(top-level)";
  lines.push(`project: ${s.project}, ${sweepLabel}`);
  lines.push(`runs.tsv: ${s.runsTsv}`);
  const statusBits = Object.entries(s.statusCounts)
    .map(([k, v]) => `${v} ${k}`)
    .join(", ");
  lines.push(`status: ${s.totalRows} total — ${statusBits || "(empty)"}`);
  lines.push(`cells: ${s.cellCount}, direction: ${s.direction} is better`);
  if (s.topCells.length) {
    lines.push("");
    lines.push("top cells (by mean_return):");
    lines.push("  rank | cell                                    | n |  mean    | std    | wandb");
    s.topCells.forEach((c, i) => {
      const mean = c.mean_return === null ? "  -   " : c.mean_return.toFixed(4).padStart(7);
      const std = c.std_return === null ? "  -   " : c.std_return.toFixed(4).padStart(6);
      const url = c.wandb_url ? c.wandb_url.slice(0, 60) : "";
      const cellName = c.name.padEnd(40).slice(0, 40);
      lines.push(`  ${String(i + 1).padStart(4)} | ${cellName} | ${String(c.seeds).padStart(1)} | ${mean} | ${std} | ${url}`);
    });
  }
  return lines.join("\n");
}

async function runWandbPull(options) {
  if (!options.name) throw new Error("project name is required");
  const library = path.resolve(options.library);
  const projectDir = path.join(library, "projects", options.name);
  const runsTsvPath = options.sweepName
    ? path.join(projectDir, "runs", `${options.sweepName}.tsv`)
    : path.join(projectDir, "runs.tsv");

  const result = await pullWandbMetrics({
    runsTsvPath,
    metric: options.metric || "mean_return",
    overwrite: options.overwrite,
  });
  return result;
}

async function main() {
  let options;
  try {
    options = parseArgs(process.argv.slice(2));
  } catch (err) {
    process.stderr.write(`${err.message}\n\n`);
    printHelp();
    process.exit(2);
  }
  if (options.help || !options.subcommand) {
    printHelp();
    process.exit(options.help ? 0 : 2);
  }
  if (!["init", "run", "summary", "wandb-pull"].includes(options.subcommand)) {
    process.stderr.write(`unknown subcommand: ${options.subcommand}\n`);
    printHelp();
    process.exit(2);
  }

  let summary;
  try {
    if (options.subcommand === "init") summary = await runInit(options);
    else if (options.subcommand === "run") summary = await runRun(options);
    else if (options.subcommand === "summary") summary = await runSummary(options);
    else summary = await runWandbPull(options);
  } catch (err) {
    process.stderr.write(`${err.message}\n`);
    process.exit(1);
  }

  if (options.json) {
    process.stdout.write(`${JSON.stringify(summary, null, 2)}\n`);
  } else if (options.subcommand === "init") {
    process.stdout.write(`planned ${summary.totalRows} rows (${summary.cells} cells × ${summary.seeds} seeds)\n`);
    process.stdout.write(`projects:    ${summary.projectDir}\n`);
    process.stdout.write(`runs.tsv:    ${summary.runsTsv}\n`);
    process.stdout.write(`commit:      ${summary.commit || "(no git)"}\n`);
    process.stdout.write(`hypothesis:  ${summary.hypothesis || "(none)"}\n`);
  } else if (options.subcommand === "run") {
    process.stdout.write(`ran ${summary.ran} rows: ok=${summary.ok}, failed=${summary.failed}, skipped=${summary.skipped}\n`);
    process.stdout.write(`runs.tsv:    ${summary.runsTsv}\n`);
  } else if (options.subcommand === "summary") {
    process.stdout.write(`${formatSummaryText(summary)}\n`);
  } else {
    // wandb-pull
    process.stdout.write(`wandb-pull: ${summary.runsTsvPath}\n`);
    process.stdout.write(`  pulled:  ${summary.pulled}\n`);
    process.stdout.write(`  skipped: ${summary.skipped}\n`);
    process.stdout.write(`  failed:  ${summary.failed}\n`);
    if (summary.failed && summary.failures.length) {
      process.stdout.write(`\n  failures:\n`);
      for (const f of summary.failures.slice(0, 10)) {
        process.stdout.write(`    ${f.name}: ${f.error}\n`);
      }
    }
    if (!summary.apiKeyConfigured && summary.skipped + summary.failed > 0) {
      process.stdout.write(`\n  hint: set WANDB_API_KEY env var if rows are erroring with auth\n`);
    }
  }
  process.exit(summary.failed && summary.failed > 0 ? 1 : 0);
}

main();
