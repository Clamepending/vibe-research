#!/usr/bin/env node

import { readFile } from "node:fs/promises";
import path from "node:path";
import process from "node:process";

const TERMINAL_STATUSES = new Set(["canceled", "cancelled", "completed", "failed"]);
const DEFAULT_SKILL_URL = "https://ottoauth.vercel.app/skill.md";

function printHelp() {
  process.stdout.write(`vr-ottoauth

Start a hosted OttoAuth task for human-linked buying/browser services.

Usage:
  vr-ottoauth --skill
  vr-ottoauth --task "Buy two packs of AA batteries" --url https://www.amazon.com --max-charge-cents 2500 --wait
  vr-ottoauth --service amazon --item-url https://www.amazon.com/... --shipping-address "Jane Doe\\n123 Main St"
  vr-ottoauth --title "snack pickup" --wait --json < order.txt

Options:
  --skill                  Print the live OttoAuth agent contract
  --task, --prompt <text>  OttoAuth task prompt
  --url <url>              Preferred website URL for computeruse tasks
  --service <id>           computeruse (default) or amazon
  --item-url <url>         Amazon product URL when --service amazon
  --title <text>           Short sidebar label
  --shipping-address <s>   Shipping/delivery address or pickup name details
  --max-charge-cents <n>   Spend cap for computeruse tasks
  --callback-url <url>     Override this agent's callback URL for multi-turn service updates
  --wait                   Poll until the hosted task completes or fails
  --json                   Print machine-readable JSON
`);
}

function parseArgs(argv) {
  const options = {
    itemUrl: "",
    json: false,
    maxChargeCents: null,
    callbackUrl: "",
    service: "computeruse",
    shippingAddress: "",
    skill: false,
    task: "",
    title: "",
    url: "",
    wait: false,
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    const readValue = (name) => {
      const inlinePrefix = `${name}=`;
      if (arg.startsWith(inlinePrefix)) {
        return arg.slice(inlinePrefix.length);
      }

      index += 1;
      return argv[index] || "";
    };

    if (arg === "--help" || arg === "-h") {
      options.help = true;
      continue;
    }

    if (arg === "--skill") {
      options.skill = true;
      continue;
    }

    if (arg === "--task" || arg.startsWith("--task=")) {
      options.task = readValue("--task");
      continue;
    }

    if (arg === "--prompt" || arg.startsWith("--prompt=")) {
      options.task = readValue("--prompt");
      continue;
    }

    if (arg === "--url" || arg.startsWith("--url=")) {
      options.url = readValue("--url");
      continue;
    }

    if (arg === "--service" || arg.startsWith("--service=")) {
      options.service = readValue("--service");
      continue;
    }

    if (arg === "--item-url" || arg.startsWith("--item-url=")) {
      options.itemUrl = readValue("--item-url");
      continue;
    }

    if (arg === "--title" || arg.startsWith("--title=")) {
      options.title = readValue("--title");
      continue;
    }

    if (arg === "--shipping-address" || arg.startsWith("--shipping-address=")) {
      options.shippingAddress = readValue("--shipping-address");
      continue;
    }

    if (arg === "--max-charge-cents" || arg.startsWith("--max-charge-cents=")) {
      options.maxChargeCents = readValue("--max-charge-cents");
      continue;
    }

    if (arg === "--callback-url" || arg.startsWith("--callback-url=")) {
      options.callbackUrl = readValue("--callback-url");
      continue;
    }

    if (arg === "--wait") {
      options.wait = true;
      continue;
    }

    if (arg === "--json") {
      options.json = true;
      continue;
    }

    throw new Error(`unknown argument: ${arg}`);
  }

  return options;
}

async function readStdin() {
  if (process.stdin.isTTY) {
    return "";
  }

  const chunks = [];
  for await (const chunk of process.stdin) {
    chunks.push(Buffer.from(chunk));
  }
  return Buffer.concat(chunks).toString("utf8");
}

async function readServerInfo(rootDir) {
  const filePath = path.join(rootDir, "server.json");
  const raw = await readFile(filePath, "utf8");
  return JSON.parse(raw);
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function fetchJsonOrThrow(url, options = {}) {
  const response = await fetch(url, options);
  const payload = await response.json().catch(() => ({}));
  if (!response.ok) {
    throw new Error(payload.error || `request failed (${response.status})`);
  }
  return payload;
}

function summarizeTask(task) {
  const result = task.result && typeof task.result === "object" ? task.result : null;
  const summary =
    (result && typeof result.summary === "string" && result.summary.trim()) ||
    task.error ||
    task.status;
  return {
    id: task.id,
    hostedTaskId: task.hostedTaskId,
    serviceId: task.serviceId,
    status: task.status,
    name: task.name,
    summary,
    orderUrl: task.orderUrl || "",
    paymentUrl: task.paymentUrl || "",
    latestUrl: task.latestUrl || task.paymentUrl || task.orderUrl || "",
    result,
    error: task.error || null,
  };
}

async function waitForCompletion(baseUrl, taskId) {
  while (true) {
    const payload = await fetchJsonOrThrow(`${baseUrl}/api/ottoauth/tasks/${encodeURIComponent(taskId)}?refresh=1`, {
      cache: "no-store",
    });
    const task = payload.task;
    if (TERMINAL_STATUSES.has(String(task.status || "").toLowerCase())) {
      return task;
    }
    await sleep(2_000);
  }
}

async function printSkill() {
  const response = await fetch(DEFAULT_SKILL_URL);
  if (!response.ok) {
    throw new Error(`could not fetch OttoAuth skill (${response.status})`);
  }
  process.stdout.write(await response.text());
}

async function main() {
  let options;
  try {
    options = parseArgs(process.argv.slice(2));
  } catch (error) {
    process.stderr.write(`vr-ottoauth: ${error.message}\n`);
    process.exit(1);
  }

  if (options.help) {
    printHelp();
    return;
  }

  if (options.skill) {
    await printSkill();
    return;
  }

  const stdinTask = options.task || options.url || options.itemUrl ? "" : (await readStdin()).trim();
  const task = (options.task || stdinTask).trim();
  const service = String(options.service || "computeruse").trim().toLowerCase();
  if (service === "computeruse" && !task && !options.url) {
    process.stderr.write("vr-ottoauth: provide --task text, --url, or stdin.\n");
    process.exit(1);
  }
  if (service === "amazon" && !options.itemUrl && !options.url) {
    process.stderr.write("vr-ottoauth: amazon service requires --item-url.\n");
    process.exit(1);
  }

  const rootDir = String(process.env.VIBE_RESEARCH_ROOT || process.env.REMOTE_VIBES_ROOT || "").trim();
  if (!rootDir) {
    process.stderr.write("vr-ottoauth: VIBE_RESEARCH_ROOT is not set.\n");
    process.exit(1);
  }

  let serverInfo;
  try {
    serverInfo = await readServerInfo(rootDir);
  } catch (error) {
    process.stderr.write(`vr-ottoauth: could not read Vibe Research server info (${error.message}).\n`);
    process.exit(1);
  }

  const baseUrl = String(serverInfo?.helperBaseUrl || "").trim();
  const token = String(serverInfo?.ottoAuthToken || "").trim();
  if (!baseUrl || !token) {
    process.stderr.write("vr-ottoauth: OttoAuth helper is not available from this session.\n");
    process.exit(1);
  }

  const requestBody = {
    callbackUrl:
      options.callbackUrl ||
      process.env.VIBE_RESEARCH_AGENT_CALLBACK_URL ||
      process.env.REMOTE_VIBES_AGENT_CALLBACK_URL ||
      "",
    callerSessionId: String(process.env.VIBE_RESEARCH_SESSION_ID || process.env.REMOTE_VIBES_SESSION_ID || "").trim(),
    cwd: process.cwd(),
    itemUrl: options.itemUrl || "",
    maxChargeCents: options.maxChargeCents,
    service,
    shippingAddress: options.shippingAddress,
    taskPrompt: task,
    title: options.title,
    url: options.url,
  };

  const payload = await fetchJsonOrThrow(`${baseUrl}/api/ottoauth/tasks`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-vibe-research-ottoauth-token": token,
    },
    body: JSON.stringify(requestBody),
  });

  let ottoAuthTask = payload.task;
  if (options.wait) {
    ottoAuthTask = await waitForCompletion(baseUrl, ottoAuthTask.id);
  }

  const summary = summarizeTask(ottoAuthTask);
  if (options.json) {
    process.stdout.write(`${JSON.stringify(summary, null, 2)}\n`);
    return;
  }

  process.stdout.write(`ottoauth ${summary.status}: ${summary.id}\n`);
  if (summary.orderUrl) {
    process.stdout.write(`order: ${summary.orderUrl}\n`);
  }
  if (summary.paymentUrl) {
    process.stdout.write(`payment: ${summary.paymentUrl}\n`);
  }
  if (summary.summary) {
    process.stdout.write(`${summary.summary}\n`);
  }
}

main().catch((error) => {
  process.stderr.write(`vr-ottoauth: ${error.message}\n`);
  process.exit(1);
});
