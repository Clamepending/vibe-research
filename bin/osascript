#!/usr/bin/env bash
set -euo pipefail

REAL_OSASCRIPT="/usr/bin/osascript"
ARGS="$*"

if printf '%s' "$ARGS" | /usr/bin/grep -Eqi 'Safari|Chrome|Brave|Arc|open location|do JavaScript'; then
  printf '[remote-vibes] Use rv-playwright open/snapshot/click/fill/type/press/screenshot instead of osascript browser automation for localhost UI work. Fall back to rv-browser only if rv-playwright fails for a concrete reason.\n' >&2
  exit 64
fi

exec "$REAL_OSASCRIPT" "$@"
