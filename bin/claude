#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLAYWRIGHT_SKILL_PATH="${VIBE_RESEARCH_PLAYWRIGHT_SKILL:-${REMOTE_VIBES_PLAYWRIGHT_SKILL:-$SCRIPT_DIR/../skills/playwright/SKILL.md}}"
GUIDANCE="Vibe Research provides two browser paths. Browser Use plugin: for delegated web/browser fulfillment, or when the user says \"use plugin\", run vr-browser-use --task \"<goal>\" --wait --json (add --url <url> and --max-steps <n> when useful). This creates a clickable Browser Use child under the current Vibe Research session; do not spawn an internal Agent for this kind of request. Playwright CLI browser skill at ${PLAYWRIGHT_SKILL_PATH}: for browser work you are directly controlling yourself, prefer vr-playwright or \$PWCLI over curl, HTML-only inspection, Chrome app scripting, Selenium, or vr-browser. First check command -v npx >/dev/null 2>&1. Then use the CLI-first loop: \$PWCLI open <url-or-localhost-port>, \$PWCLI snapshot, interact with fresh element refs via click/fill/type/press, snapshot again after UI changes, and save artifacts under output/playwright/. Always snapshot before using refs like e12. Prefer explicit Playwright CLI commands over eval/run-code unless needed. If vr-playwright cannot run because npx or the Playwright browser runtime is unavailable, report the concrete failure and fall back to vr-browser. For qualitative visual critique of generated images, vr-browser describe-file <image-path> --provider claude --prompt \"...\" remains available as a fallback so the visual pass stays on Claude."

read_agent_prompt() {
  local prompt_path
  prompt_path="${VIBE_RESEARCH_AGENT_PROMPT_PATH:-${REMOTE_VIBES_AGENT_PROMPT_PATH:-}}"

  if [ -n "$prompt_path" ] && [ -f "$prompt_path" ]; then
    cat "$prompt_path"
  fi
}

build_combined_guidance() {
  local agent_prompt
  agent_prompt="$(read_agent_prompt || true)"

  if [ -n "$agent_prompt" ]; then
    printf '%s\n\n%s\n' "$GUIDANCE" "$agent_prompt"
    return
  fi

  printf '%s\n' "$GUIDANCE"
}

find_real_claude() {
  local candidate

  for candidate in \
    "${VIBE_RESEARCH_REAL_CLAUDE_COMMAND:-}" \
    "${REMOTE_VIBES_REAL_CLAUDE_COMMAND:-}" \
    "${HOME:-}/.local/bin/claude" \
    /opt/homebrew/bin/claude \
    /usr/local/bin/claude \
    "$(command -v claude 2>/dev/null || true)"; do
    if [ -n "$candidate" ] && [ -x "$candidate" ] && [ "$candidate" != "$SCRIPT_DIR/claude" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

REAL_CLAUDE="$(find_real_claude || true)"
if [ -z "$REAL_CLAUDE" ]; then
  printf '[vibe-research] Could not find the real claude executable for the wrapper.\n' >&2
  exit 1
fi

export VIBE_RESEARCH_PROVIDER="claude"
export REMOTE_VIBES_PROVIDER="${REMOTE_VIBES_PROVIDER:-claude}"

COMBINED_GUIDANCE="$(build_combined_guidance)"

exec "$REAL_CLAUDE" --append-system-prompt "$COMBINED_GUIDANCE" "$@"
