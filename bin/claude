#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLAYWRIGHT_SKILL_PATH="${REMOTE_VIBES_PLAYWRIGHT_SKILL:-$SCRIPT_DIR/../skills/playwright/SKILL.md}"
GUIDANCE="Remote Vibes provides a Playwright CLI browser skill at ${PLAYWRIGHT_SKILL_PATH}. For web UI inspection, navigation, screenshots, and interaction flows, prefer rv-playwright or \$PWCLI over curl, HTML-only inspection, Chrome app scripting, Selenium, or rv-browser. First check command -v npx >/dev/null 2>&1. Then use the CLI-first loop: \$PWCLI open <url-or-localhost-port>, \$PWCLI snapshot, interact with fresh element refs via click/fill/type/press, snapshot again after UI changes, and save artifacts under output/playwright/. Always snapshot before using refs like e12. Prefer explicit Playwright CLI commands over eval/run-code unless needed. If rv-playwright cannot run because npx or the Playwright browser runtime is unavailable, report the concrete failure and fall back to rv-browser. For qualitative visual critique of generated images, rv-browser describe-file <image-path> --provider claude --prompt \"...\" remains available as a fallback so the visual pass stays on Claude."

read_agent_prompt() {
  local prompt_path
  prompt_path="${REMOTE_VIBES_AGENT_PROMPT_PATH:-}"

  if [ -n "$prompt_path" ] && [ -f "$prompt_path" ]; then
    cat "$prompt_path"
  fi
}

build_combined_guidance() {
  local agent_prompt
  agent_prompt="$(read_agent_prompt || true)"

  if [ -n "$agent_prompt" ]; then
    printf '%s\n\n%s\n' "$GUIDANCE" "$agent_prompt"
    return
  fi

  printf '%s\n' "$GUIDANCE"
}

find_real_claude() {
  local candidate

  for candidate in \
    "${REMOTE_VIBES_REAL_CLAUDE_COMMAND:-}" \
    "${HOME:-}/.local/bin/claude" \
    /opt/homebrew/bin/claude \
    /usr/local/bin/claude \
    "$(command -v claude 2>/dev/null || true)"; do
    if [ -n "$candidate" ] && [ -x "$candidate" ] && [ "$candidate" != "$SCRIPT_DIR/claude" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

REAL_CLAUDE="$(find_real_claude || true)"
if [ -z "$REAL_CLAUDE" ]; then
  printf '[remote-vibes] Could not find the real claude executable for the wrapper.\n' >&2
  exit 1
fi

export REMOTE_VIBES_PROVIDER="claude"

COMBINED_GUIDANCE="$(build_combined_guidance)"

exec "$REAL_CLAUDE" --append-system-prompt "$COMBINED_GUIDANCE" "$@"
