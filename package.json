{
  "name": "vibe-research",
  "version": "1.0.19",
  "description": "Minimal browser-based terminal sessions for local coding agents over Tailscale.",
  "private": true,
  "type": "module",
  "bin": {
    "vibe-research": "./bin/vibe-research",
    "vr-agent-canvas": "./bin/vr-agent-canvas",
    "vr-agent-town": "./bin/vr-agent-town",
    "vr-claude-stream-chat": "./bin/vr-claude-stream-chat",
    "vr-claude-stream-experiment": "./bin/vr-claude-stream-experiment",
    "vr-agentmail-reply": "./bin/vr-agentmail-reply",
    "vr-browser": "./bin/vr-browser",
    "vr-browser-use": "./bin/vr-browser-use",
    "vr-mailwatch": "./bin/vr-mailwatch",
    "vr-ottoauth": "./bin/vr-ottoauth",
    "vr-playwright": "./bin/vr-playwright",
    "vr-scaffold-recipe": "./bin/vr-scaffold-recipe",
    "vr-session-name": "./bin/vr-session-name",
    "vr-telegram-reply": "./bin/vr-telegram-reply",
    "vr-videomemory": "./bin/vr-videomemory",
    "rv-browser": "./bin/rv-browser",
    "rv-agent-canvas": "./bin/rv-agent-canvas",
    "rv-agentmail-reply": "./bin/rv-agentmail-reply",
    "rv-browser-use": "./bin/rv-browser-use",
    "rv-mailwatch": "./bin/rv-mailwatch",
    "rv-ottoauth": "./bin/rv-ottoauth",
    "rv-scaffold-recipe": "./bin/rv-scaffold-recipe",
    "rv-session-name": "./bin/rv-session-name",
    "rv-telegram-reply": "./bin/rv-telegram-reply",
    "rv-videomemory": "./bin/rv-videomemory",
    "rv-playwright": "./bin/rv-playwright",
    "playwright-cli": "./bin/playwright-cli"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.mjs",
    "build": "node scripts/build-client.mjs",
    "start": "npm run build && node src/server.js",
    "dev:local": "npm run build && VIBE_RESEARCH_PORT=4828 VIBE_RESEARCH_STATE_DIR=output/dev-state VIBE_RESEARCH_WORKSPACE_DIR=/Users/mark/vibe-projects node src/server.js",
    "dev": "node --watch src/server.js",
    "release:assets": "node scripts/build-release-assets.mjs",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "desktop:install": "npm --prefix desktop install",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:pack": "npm --prefix desktop run pack",
    "desktop:dist": "npm --prefix desktop run dist",
    "desktop:test": "npm --prefix desktop test",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "http-proxy": "^1.18.1",
    "lucide": "^1.11.0",
    "marked": "^15.0.12",
    "node-pty": "npm:@lydell/node-pty@^1.2.0-beta.12",
    "playwright-core": "^1.59.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.2",
    "xterm": "^5.3.0",
    "xterm-addon-canvas": "^0.5.0",
    "xterm-addon-webgl": "^0.16.0"
  }
}
