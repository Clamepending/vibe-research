{
  "name": "vibe-research-desktop",
  "version": "0.2.18",
  "description": "Desktop launcher and first-run installer for Vibe Research.",
  "private": true,
  "main": "src/main.cjs",
  "scripts": {
    "icons": "node scripts/create-icons.mjs",
    "dev": "electron .",
    "pack": "npm run icons && electron-builder --dir",
    "dist": "npm run icons && electron-builder",
    "dist:mas": "npm run icons && electron-builder --mac mas --universal --publish never",
    "test": "node --test test/*.test.cjs"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "net.vibe-research.desktop",
    "productName": "Vibe Research",
    "artifactName": "Vibe-Research-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Clamepending",
        "repo": "vibe-research"
      }
    ],
    "files": [
      "package.json",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "../install.sh",
        "to": "install.sh"
      },
      {
        "from": "../release-channel.json",
        "to": "release-channel.json"
      },
      {
        "from": "..",
        "to": "app-template",
        "filter": [
          "bin/**",
          "docs/**",
          "public/index.html",
          "public/styles.css",
          "scripts/**",
          "skills/**",
          "src/**",
          "templates/**",
          "install.sh",
          "LICENSE",
          "package-lock.json",
          "package.json",
          "README.md",
          "release-channel.json",
          "SECURITY.md",
          "start.sh",
          "SUPPORT.md",
          "TRADEMARK.md"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "Vibe Research uses the camera only when you choose camera or browser features that request it.",
        "NSMicrophoneUsageDescription": "Vibe Research uses the microphone only when you choose voice input or browser features that request it.",
        "NSBluetoothAlwaysUsageDescription": "Vibe Research does not use Bluetooth directly.",
        "NSBluetoothPeripheralUsageDescription": "Vibe Research does not use Bluetooth directly."
      }
    },
    "mas": {
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "target": [
        "mas"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
